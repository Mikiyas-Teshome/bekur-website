{
  "$schema": "../schema/sitemap.schema.json",
  "version": "1.0",
  "baseUrl": "https://www.bekurtechnologies.com",
  "routes": [
    {
      "path": "/",
      "pageId": "home",
      "type": "static",
      "changefreq": "weekly",
      "priority": 1.0,
      "contentFile": "content/pages/home.json"
    },
    {
      "path": "/automation-sprint",
      "pageId": "automation-sprint",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.9,
      "contentFile": "content/pages/automation-sprint.json"
    },
    {
      "path": "/blueprint",
      "pageId": "blueprint",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.9,
      "contentFile": "content/pages/blueprint.json"
    },
    {
      "path": "/how-we-work",
      "pageId": "how-we-work",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.8,
      "contentFile": "content/pages/how-we-work.json"
    },
    {
      "path": "/who-we-serve",
      "pageId": "who-we-serve",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.8,
      "contentFile": "content/pages/who-we-serve.json"
    },
    {
      "path": "/why-bekur",
      "pageId": "why-bekur",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.8,
      "contentFile": "content/pages/why-bekur.json"
    },
    {
      "path": "/pricing",
      "pageId": "pricing",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.7,
      "contentFile": "content/pages/pricing.json"
    },
    {
      "path": "/faq",
      "pageId": "faq",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.7,
      "contentFile": "content/pages/faq.json"
    },
    {
      "path": "/about",
      "pageId": "about",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.6,
      "contentFile": "content/pages/about.json"
    },
    {
      "path": "/contact",
      "pageId": "contact",
      "type": "static",
      "changefreq": "monthly",
      "priority": 0.8,
      "contentFile": "content/pages/contact.json"
    },
    {
      "path": "/blog",
      "pageId": "blog-index",
      "type": "dynamic",
      "changefreq": "daily",
      "priority": 0.8,
      "dataSource": "blog_posts",
      "isrRevalidateSeconds": 3600
    },
    {
      "path": "/blog/[slug]",
      "pageId": "blog-detail",
      "type": "dynamic",
      "changefreq": "weekly",
      "priority": 0.7,
      "dataSource": "blog_posts",
      "isrRevalidateSeconds": 3600,
      "onDemandRevalidation": true
    },
    {
      "path": "/portfolio",
      "pageId": "portfolio-index",
      "type": "dynamic",
      "changefreq": "weekly",
      "priority": 0.8,
      "dataSource": "portfolio_projects",
      "isrRevalidateSeconds": 3600
    },
    {
      "path": "/portfolio/[slug]",
      "pageId": "portfolio-detail",
      "type": "dynamic",
      "changefreq": "monthly",
      "priority": 0.7,
      "dataSource": "portfolio_projects",
      "isrRevalidateSeconds": 3600,
      "onDemandRevalidation": true
    }
  ],
  "excludedFromSitemap": [
    "/admin",
    "/admin/login",
    "/api"
  ],
  "retiredPaths": [
    "/services",
    "/services/outsource",
    "/services/digital-marketing",
    "/services/social-media-management",
    "/services/social-media",
    "/services/website-development",
    "/services/app-development",
    "/services/ui-ux",
    "/services/graphics-design",
    "/mvp"
  ]
}
