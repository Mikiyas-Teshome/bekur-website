  "migrationPatterns": [
    {
      "source": "/blog/:id",
      "destination": "/blog/:slug",
      "permanent": true,
      "note": "Do not add to next.config as a pattern — generate one redirect per published post from database slug map"
    },
    {
      "source": "/portfolio/:id",
      "destination": "/portfolio/:slug",
      "permanent": true,
      "note": "Same as blog; output file redirects.migration.json"
    }
  ]
}
