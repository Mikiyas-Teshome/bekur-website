    },
    {
      "source": "/services/digital-marketing",
      "destination": "/automation-sprint",
      "permanent": true,
      "reason": "Legacy service page"
    },
    {
      "source": "/services/social-media-management",
      "destination": "/automation-sprint",
      "permanent": true,
      "reason": "Legacy service page"
    },
    {
      "source": "/services/social-media",
      "destination": "/automation-sprint",
      "permanent": true,
